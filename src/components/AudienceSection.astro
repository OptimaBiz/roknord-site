---
const audiences = [
  {
    id: "audience-testing",
    title: "Испытательным лабораториям",
    text: "Чаще всего смотрим методики, оборудование, персонал и трассировку записей.",
    link: "Узнать больше",
    href: "/testing-labs/",
    image: "/images/materials/lab.webp",
    imageAlt: "Сотрудники испытательной лаборатории за работой с микроскопом и документами",
  },
  {
    id: "audience-medical",
    title: "Медицинским лабораториям",
    text: "Сопоставляем процессы, записи, персонал и следы лабораторной практики.",
    link: "Узнать больше",
    href: "/medical-labs/",
    image: "/images/materials/medlab.webp",
  },
  {
    id: "audience-cert-ms",
    title: "Органам по сертификации систем менеджмента",
    text: "Смотрим СМК, выборку дел, компетентность и управляемость решений.",
    link: "Узнать больше",
    href: "/certification-bodies/",
    image: "/images/materials/смк.webp",
  },
  {
    id: "audience-cert-product",
    title: "Органам по сертификации продукции",
    text: "Проверяем область, протоколы, несоответствия и следы корректировки.",
    link: "Узнать больше",
    href: "/certification-bodies/",
    image: "/images/materials/product.webp",
  },
  {
    id: "audience-inspection",
    title: "Органам инспекции",
    text: "Оцениваем область, процедуры, записи выездов и наблюдений.",
    link: "Узнать больше",
    href: "#contact",
    image: "/images/materials/insp.webp",
  },
  {
    id: "audience-calibration",
    title: "Калибровочным лабораториям",
    text: "Сверяем методики, эталоны, прослеживаемость и документы.",
    link: "Узнать больше",
    href: "#contact",
    image: "/images/materials/calibro.webp",
  },
  {
    id: "audience-msi",
    title: "Провайдерам МСИ",
    text: "Смотрим программу, доказательства участия и корректность фиксации.",
    link: "Узнать больше",
    href: "#contact",
    image: "/images/materials/metodasi.webp",
  },
  {
    id: "audience-halal",
    title: "Органам по сертификации халяль",
    text: "Проверяем состав области, источники доказательств и логику согласования.",
    link: "Узнать больше",
    href: "#contact",
    image: "/images/materials/halal.webp",
    logo: "/images/materials/halal_logo_v5.svg",
    logoAlt: "Логотип халяль",
  },
];
---

<section id="deliverables" class="section section--light">
  <div class="section__inner section-stack page-container">
    <header class="section-stack section-scope">
      <p class="section__eyebrow">Помогаем нашим Клиентам</p>
      <h2 class="section__title">Для каждого типа аккредитованного лица различные доказательства и практика их применения.</h2>
      <p class="section__lead">Создаем не просто комплект документов, а систему, в которой область, записи и фактическая работа сходятся между собой.</p>
    </header>

    <div class="audience-grid" aria-label="Помогаем нашим Клиентам">
      {audiences.map((item) => (
        <article
          id={item.id}
          class="card audience-card"
          style={item.image ? `--bg-image: url('${item.image}');` : undefined}
        >
          {item.logo && (
            <div class="audience-card__logo-wrap">
              <img
                class="audience-card__logo"
                src={item.logo}
                alt={item.logoAlt ?? ""}
                width="680"
                height="420"
                decoding="async"
              />
            </div>
          )}
          <h3 class="card__title">{item.title}</h3>
          <p class="card__text">{item.text}</p>
          <a class="card__link" href={item.href}>
            <span aria-hidden="true">→</span>
            <span>{item.link}</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .audience-card {
    position: relative;
    z-index: 0;
    min-height: 26rem;
    align-content: end;
    color: var(--lrqa-white);
    background: transparent;
    border-color: transparent;
    cursor: pointer;
  }

  /* фон — фото или плейсхолдер, GPU-слой */
  .audience-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-color: var(--lrqa-navy-2);
    background-image: var(--bg-image, none);
    background-size: cover;
    background-position: center;
    filter: saturate(0.30) contrast(0.88) brightness(0.95) grayscale(0.25);
    pointer-events: none;
    transform: translateZ(0);
  }

  /* затемнение */
  .audience-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    background: rgba(14, 11, 58, 0.62);
    pointer-events: none;
    transition: background 0.15s ease;
  }

  @media (hover: hover) {
    .audience-card:hover::before,
    .audience-card:focus-within::before {
      background: rgba(14, 11, 58, 0.90);
    }
  }

  .audience-card.is-tapped::before {
    background: rgba(14, 11, 58, 0.90);
  }

  .audience-card__logo-wrap {
    position: absolute;
    top: var(--space-5);
    left: calc(var(--space-5) - 20%);
    z-index: 1;
    width: min(80%, 25rem);
    pointer-events: none;
  }

  .audience-card__logo {
    display: block;
    width: 100%;
    height: auto;
  }

  .audience-card .card__title,
  .audience-card .card__text,
  .audience-card .card__link {
    position: relative;
    z-index: 3;
  }

  .audience-card .card__title {
    color: var(--lrqa-white);
    font-size: clamp(1.5rem, 2.5vw + 0.7rem, 2.25rem);
  }

  .audience-card .card__text {
    color: var(--lrqa-border-soft);
  }

  .audience-card .card__link {
    color: var(--lrqa-white);
    text-decoration: none;
    border-bottom: none;
  }

  .audience-card .card__link span[aria-hidden] {
    color: var(--lrqa-mint);
    display: inline-block;
    will-change: transform;
  }

  @keyframes arrow-fwd {
    0%   { transform: translateX(0); }
    100% { transform: translateX(7px); }
  }

  @media (hover: hover) {
    .audience-card:hover .card__link span[aria-hidden],
    .audience-card:focus-within .card__link span[aria-hidden] {
      animation: arrow-fwd 0.9s ease-in-out infinite alternate;
    }
  }

  .audience-card.is-tapped .card__link span[aria-hidden] {
    animation: arrow-fwd 0.9s ease-in-out infinite alternate;
  }

  @media (prefers-reduced-motion: reduce) {
    .audience-card,
    .audience-card::after,
    .audience-card::before {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".audience-card");
  let activeCard: HTMLElement | null = null;

  function clearCard(card: HTMLElement) {
    card.classList.remove("is-tapped");
    if (activeCard === card) activeCard = null;
  }

  cards.forEach((card) => {
    let didMove = false;

    card.addEventListener("touchstart", () => {
      didMove = false;
      if (activeCard && activeCard !== card) activeCard.classList.remove("is-tapped");
      card.classList.add("is-tapped");
      activeCard = card;
    }, { passive: true });

    card.addEventListener("touchmove", () => {
      if (!didMove) {
        didMove = true;
        clearCard(card);
      }
    }, { passive: true });

    card.addEventListener("touchcancel", () => {
      clearCard(card);
    }, { passive: true });
  });

  // Снимаем эффект если тап вне карточки
  document.addEventListener("touchstart", (e) => {
    if (activeCard && !(e.target as Element).closest(".audience-card")) {
      clearCard(activeCard);
    }
  }, { passive: true });
</script>

<section class="promo-feature" aria-labelledby="promo-feature-title">
  <div class="page-container">
    <article class="promo-card framed-card framed-card--dark framed-card--large">
      <span class="promo-frame" aria-hidden="true">
        <span class="promo-frame__line promo-frame__line--top"></span>
        <span class="promo-frame__line promo-frame__line--right"></span>
        <span class="promo-frame__line promo-frame__line--bottom"></span>
        <span class="promo-frame__line promo-frame__line--left"></span>
        <span class="promo-frame__line promo-frame__line--bevel"></span>
      </span>
      <span class="promo-label framed-card__label editorial-label-tab">ЭКСПЕРТНЫЙ МАТЕРИАЛ</span>
      <div class="promo-copy framed-card__content">
        <h2 id="promo-feature-title" class="promo-title">
          Подготовка доказательной базы перед ПК в ФСА
        </h2>
        <p class="promo-text">
          В документе описано 
          что нужно проверить, 
          типичные ошибки и 
          критерии самодиагностики.
        </p>
        <a class="promo-cta cta-angled" href="/materials/karta-riskov-pk-os-smk-2026/">
          <span>Скачать бесплатно</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="promo-visual">
        <div
          class="promo-cover"
          data-promo-cover-pan
          tabindex="0"
          aria-label="Интерактивный просмотр первой страницы материала"
        >
          <iframe
            class="promo-cover__frame"
            src="/pdf/roknord_karta_riskov_pk_os_smk_2026.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH"
            title="Обложка материала: карта рисков перед подтверждением компетентности"
            loading="lazy"
            tabindex="-1"
          ></iframe>
        </div>
      </div>
    </article>
  </div>
</section>

<script>
  (() => {
    const cover = document.querySelector('[data-promo-cover-pan]');
    if (!cover) return;

    const frame = cover.querySelector('.promo-cover__frame');

    let panX = 0;
    let panY = 0;
    let velX = 0;
    let velY = 0;
    let isDragging = false;
    let startClientX = 0;
    let startClientY = 0;
    let startPanX = 0;
    let startPanY = 0;
    let lastClientX = 0;
    let lastClientY = 0;
    let rafId = null;

    const clamp = (v, a, b) => Math.min(Math.max(v, a), b);

    const maxPan = () => {
      const fw = frame.offsetWidth;
      const fh = frame.offsetHeight;
      const cw = cover.offsetWidth;
      const ch = cover.offsetHeight;
      return {
        x: Math.max(0, (fw - cw) / 2),
        y: Math.max(0, fh - ch),
      };
    };

    const commit = () => {
      const m = maxPan();
      panX = clamp(panX, -m.x, m.x);
      panY = clamp(panY, -m.y, 0);
      cover.style.setProperty('--cover-pan-x', `${panX}px`);
      cover.style.setProperty('--cover-pan-y', `${panY}px`);
    };

    const glide = () => {
      velX *= 0.87;
      velY *= 0.87;
      panX += velX;
      panY += velY;
      commit();
      if (Math.abs(velX) > 0.4 || Math.abs(velY) > 0.4) {
        rafId = requestAnimationFrame(glide);
      }
    };

    cover.addEventListener('pointerdown', (e) => {
      isDragging = true;
      startClientX = e.clientX;
      startClientY = e.clientY;
      startPanX = panX;
      startPanY = panY;
      lastClientX = e.clientX;
      lastClientY = e.clientY;
      velX = 0;
      velY = 0;
      cancelAnimationFrame(rafId);
      cover.classList.add('is-panning');
      cover.setPointerCapture?.(e.pointerId);
    });

    cover.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      velX = e.clientX - lastClientX;
      velY = e.clientY - lastClientY;
      lastClientX = e.clientX;
      lastClientY = e.clientY;
      panX = startPanX + (e.clientX - startClientX);
      panY = startPanY + (e.clientY - startClientY);
      commit();
    });

    const stopDrag = (e) => {
      if (!isDragging) return;
      isDragging = false;
      cover.classList.remove('is-panning');
      cover.releasePointerCapture?.(e.pointerId);
      rafId = requestAnimationFrame(glide);
    };

    cover.addEventListener('pointerup', stopDrag);
    cover.addEventListener('pointercancel', stopDrag);

    cover.addEventListener('keydown', (e) => {
      const stepY = cover.offsetHeight * 0.12;
      const stepX = cover.offsetWidth * 0.08;
      const m = maxPan();
      if (e.key === 'Escape') { panX = 0; panY = 0; commit(); return; }
      if (!['ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.key)) return;
      e.preventDefault();
      if (e.key === 'ArrowUp')    panY = clamp(panY + stepY, -m.y, 0);
      if (e.key === 'ArrowDown')  panY = clamp(panY - stepY, -m.y, 0);
      if (e.key === 'ArrowLeft')  panX = clamp(panX + stepX, -m.x, m.x);
      if (e.key === 'ArrowRight') panX = clamp(panX - stepX, -m.x, m.x);
      commit();
    });
  })();
</script>

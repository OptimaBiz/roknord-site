<section class="promo-feature" aria-labelledby="promo-feature-title">
  <div class="page-container">
    <article class="promo-card framed-card framed-card--dark framed-card--large">
      <span class="promo-frame" aria-hidden="true">
        <span class="promo-frame__line promo-frame__line--top"></span>
        <span class="promo-frame__line promo-frame__line--right"></span>
        <span class="promo-frame__line promo-frame__line--bottom"></span>
        <span class="promo-frame__line promo-frame__line--left"></span>
        <span class="promo-frame__line promo-frame__line--bevel"></span>
      </span>
      <span class="promo-label framed-card__label editorial-label-tab">ЭКСПЕРТНЫЙ МАТЕРИАЛ</span>
      <div class="promo-copy framed-card__content">
        <h2 id="promo-feature-title" class="promo-title">
          Подготовка доказательной базы перед ПК в ФСА
        </h2>
        <p class="promo-text">
          В документе описано 
          что нужно проверить, 
          типичные ошибки и 
          критерии самодиагностики.
        </p>
        <a class="promo-cta cta-angled" href="/materials/karta-riskov-pk-os-smk-2026/">
          <span>Скачать бесплатно</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="promo-visual">
        <div
          class="promo-cover"
          data-promo-cover-pan
          tabindex="0"
          aria-label="Интерактивный просмотр первой страницы материала"
        >
          <iframe
            class="promo-cover__frame"
            src="/pdf/roknord_karta_riskov_pk_os_smk_2026.pdf#page=1&toolbar=0&navpanes=0&scrollbar=0&view=FitH"
            title="Обложка материала: карта рисков перед подтверждением компетентности"
            loading="lazy"
            tabindex="-1"
          ></iframe>
        </div>
      </div>
    </article>
  </div>
</section>

<script>
  (() => {
    const cover = document.querySelector('[data-promo-cover-pan]');
    if (!cover) return;

    let isPanning = false;
    let keyboardX = 0;
    let keyboardY = 0;

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const setPan = (clientX, clientY) => {
      const rect = cover.getBoundingClientRect();
      const ratioX = clamp((clientX - rect.left) / rect.width, 0, 1);
      const ratioY = clamp((clientY - rect.top) / rect.height, 0, 1);
      const maxX = rect.width * 0.22;
      const maxY = rect.height * 0.22;

      keyboardX = (0.5 - ratioX) * 2 * maxX;
      keyboardY = (0.5 - ratioY) * 2 * maxY;

      cover.style.setProperty('--cover-pan-x', `${keyboardX}px`);
      cover.style.setProperty('--cover-pan-y', `${keyboardY}px`);
    };

    const setKeyboardPan = () => {
      cover.style.setProperty('--cover-pan-x', `${keyboardX}px`);
      cover.style.setProperty('--cover-pan-y', `${keyboardY}px`);
    };

    const resetPan = () => {
      keyboardX = 0;
      keyboardY = 0;
      cover.style.setProperty('--cover-pan-x', '0px');
      cover.style.setProperty('--cover-pan-y', '0px');
    };

    cover.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'mouse') setPan(event.clientX, event.clientY);
    });

    cover.addEventListener('pointermove', (event) => {
      if (event.pointerType !== 'mouse' && !isPanning) return;
      setPan(event.clientX, event.clientY);
    });

    cover.addEventListener('pointerdown', (event) => {
      isPanning = true;
      cover.classList.add('is-panning');
      cover.setPointerCapture?.(event.pointerId);
      setPan(event.clientX, event.clientY);
    });

    const stopPanning = (event) => {
      isPanning = false;
      cover.classList.remove('is-panning');
      cover.releasePointerCapture?.(event.pointerId);
    };

    cover.addEventListener('pointerup', stopPanning);
    cover.addEventListener('pointercancel', stopPanning);

    cover.addEventListener('pointerleave', (event) => {
      if (event.pointerType === 'mouse' && !isPanning) resetPan();
    });

    cover.addEventListener('keydown', (event) => {
      const rect = cover.getBoundingClientRect();
      const stepX = rect.width * 0.07;
      const stepY = rect.height * 0.07;
      const maxX = rect.width * 0.22;
      const maxY = rect.height * 0.22;

      if (event.key === 'Escape') {
        resetPan();
        return;
      }

      if (!['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown'].includes(event.key)) return;
      event.preventDefault();

      if (event.key === 'ArrowLeft') keyboardX = clamp(keyboardX + stepX, -maxX, maxX);
      if (event.key === 'ArrowRight') keyboardX = clamp(keyboardX - stepX, -maxX, maxX);
      if (event.key === 'ArrowUp') keyboardY = clamp(keyboardY + stepY, -maxY, maxY);
      if (event.key === 'ArrowDown') keyboardY = clamp(keyboardY - stepY, -maxY, maxY);

      setKeyboardPan();
    });
  })();
</script>

---
import MobileMenu from "./MobileMenu.astro";

const serviceLinks = [
  { label: "Подготовка к подтверждению компетентности", href: "/#scenario-confirmation" },
  { label: "Аудит и актуализация области аккредитации", href: "/#scenario-scope-audit" },
  { label: "Корректирующие действия после несоответствий", href: "/#scenario-corrective-actions" },
  { label: "Подготовка к первичной аккредитации", href: "/#scenario-primary-accreditation" },
  { label: "Специальные направления", href: "/#scenario-special-directions" },
];

const audienceLinks = [
  { label: "Испытательным лабораториям", href: "/#audience-testing" },
  { label: "Медицинским лабораториям", href: "/#audience-medical" },
  { label: "Органам по сертификации систем менеджмента", href: "/#audience-cert-ms" },
  { label: "Органам по сертификации продукции", href: "/#audience-cert-product" },
  { label: "Органам инспекции", href: "/#audience-inspection" },
  { label: "Калибровочным лабораториям", href: "/#audience-calibration" },
  { label: "Провайдерам МСИ", href: "/#audience-msi" },
  { label: "Органам по сертификации халяль", href: "/#audience-halal" },
];

const utilityLinks = [
  { label: "О компании", href: "/#authority" },
  { label: "Личный кабинет", href: "#", isLogin: true },
  { label: "Карьера", href: "/#contact" },
  { label: "Партнерам", href: "/#contact" },
  { label: "Контакты", href: "/#contact" },
];

const sectionLinks = [
  { label: "Сценарии помощи", href: "/#directions" },
  { label: "Помогаем нашим Клиентам", href: "/#deliverables" },
  { label: "Ключевые услуги", href: "/#resources" },
  { label: "Карта проверки", href: "/#authority" },
  { label: "Как работаем", href: "/#formats" },
  { label: "Вопросы", href: "/#faq" },
  { label: "Контакты", href: "/#contact" },
];
---

<header class="header">
  <div class="header-service" aria-label="Служебная навигация">
    <div class="topbar__inner header-service-inner page-container">
      <nav class="utility-nav" aria-label="Служебные ссылки">
        {utilityLinks.map((item) => (
          item.isLogin
            ? <a href={item.href} data-login-trigger>{item.label}</a>
            : <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <a class="service-account service-account--mobile" href="#" data-login-trigger>
        <img class="service-account__icon" src="/icons/account_icon_1.svg" alt="" aria-hidden="true" decoding="async" />
        <span>Личный кабинет</span>
      </a>
      <a class="service-cta cta-angled" href="/#contact">Бесплатная консультация</a>
      <a class="service-cta service-cta--mobile" href="/#contact">Связаться</a>
    </div>
  </div>

  <div class="header__inner header-inner page-container">
    <div class="header-primary">
      <a class="brand" href="/" aria-label="Рокнорд, на главную страницу">
        <img
          class="brand-logo"
          src="/images/brand/roknord-logo-transparent.png"
          width="2508"
          height="627"
          alt="Рокнорд"
        />
      </a>

      <nav class="site-nav" aria-label="Основная навигация">
        <details class="nav-dropdown">
          <summary aria-controls="services-panel" aria-expanded="false">Услуги</summary>
          <div class="nav-dropdown-panel" id="services-panel">
            <div class="container nav-dropdown-inner">
              <p class="nav-dropdown-title">Услуги</p>
              <div class="nav-dropdown-list">
                {serviceLinks.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </div>
            </div>
          </div>
        </details>
        <details class="nav-dropdown">
          <summary aria-controls="audience-panel" aria-expanded="false">Помогаем нашим Клиентам</summary>
          <div class="nav-dropdown-panel" id="audience-panel">
            <div class="container nav-dropdown-inner">
              <p class="nav-dropdown-title">Помогаем нашим Клиентам</p>
              <div class="nav-dropdown-list nav-dropdown-list--columns">
                {audienceLinks.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </div>
            </div>
          </div>
        </details>
      </nav>

      <MobileMenu
        serviceLinks={serviceLinks}
        audienceLinks={audienceLinks}
        utilityLinks={utilityLinks}
      />
    </div>
  </div>

  <script is:inline>
    (() => {
      const headerRoot = document.currentScript?.closest('header') || document.querySelector('.header');
      const dropdowns = headerRoot ? Array.from(headerRoot.querySelectorAll('.nav-dropdown')) : [];
      const mobileMenu = headerRoot?.querySelector('.mobile-menu');

    const syncExpandedState = (details) => {
      const summary = details.querySelector('summary');
      if (summary) summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
      const panel = details.querySelector('.nav-dropdown-panel, .mobile-menu-panel');
      if (panel && panel.id) {
        summary?.setAttribute('aria-controls', panel.id);
      }
    };

    const closeAll = () => {
      dropdowns.forEach((dropdown) => {
        dropdown.open = false;
        syncExpandedState(dropdown);
      });
      if (mobileMenu) {
        mobileMenu.open = false;
        syncExpandedState(mobileMenu);
        document.body.style.overflow = '';
      }
    };

    dropdowns.forEach((dropdown) => {
      syncExpandedState(dropdown);
      dropdown.addEventListener('toggle', () => {
        syncExpandedState(dropdown);
        if (!dropdown.open) return;
        dropdowns.forEach((other) => {
          if (other !== dropdown) {
            other.open = false;
            syncExpandedState(other);
          }
        });
        if (mobileMenu?.open) {
          mobileMenu.open = false;
          syncExpandedState(mobileMenu);
        }
      });

      dropdown.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeAll);
      });
    });

    if (mobileMenu) {
      syncExpandedState(mobileMenu);
      mobileMenu.addEventListener('toggle', () => {
        syncExpandedState(mobileMenu);
        if (mobileMenu.open) {
          document.body.style.overflow = 'hidden';
          dropdowns.forEach((dropdown) => {
            dropdown.open = false;
            syncExpandedState(dropdown);
          });
        } else {
          document.body.style.overflow = '';
        }
      });

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeAll);
      });
    }

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      if (event.target.closest('.header')) return;
      closeAll();
    });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeAll();
      });
    })();
  </script>
</header>

---
import HeroMedia from "./HeroMedia.astro";
---

<section id="top" class="hero hero--cinematic">
  <div class="hero__media-layer" aria-hidden="true">
    <HeroMedia
      posterSrc="/images/hero/roknord-hero-poster.jpg"
      posterAlt=""
      mobileVideoMp4Src="/videos/hero/Кинематографический.mp4"
      videoMp4Src="/videos/hero/reklamnyi-desktop-cropped.mp4"
    />
  </div>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__inner hero-layout page-container">
    <div class="hero-statement">
      <div class="hero-title-block">
        <h1 class="hero-title">
          <span class="hero-title__line hero-title__line--desktop">Комплексная</span>
          <span class="hero-title__line hero-title__line--desktop">подготовка</span>
          <span class="hero-title__line hero-title__line--desktop">к аккредитации</span>
          <span class="hero-title__line hero-title__line--desktop">и подтверждению</span>
          <span class="hero-title__line hero-title__line--desktop"><span class="hero-title__accent">компетентности</span></span>
          <span class="hero-title__line hero-title__line--mobile">Комплексная</span>
          <span class="hero-title__line hero-title__line--mobile">подготовка</span>
          <span class="hero-title__line hero-title__line--mobile">к аккредитации</span>
          <span class="hero-title__line hero-title__line--mobile">и подтверждению</span>
          <span class="hero-title__line hero-title__line--mobile"><span class="hero-title__accent">компетентности</span></span>
        </h1>
      </div>
    </div>

    <div class="hero-supporting">
      <div class="hero-lead-block">
        <p class="hero-lead">
          Понимаем, как эксперты ФСА смотрят на документы, область аккредитации, процессы, доказательства и риски.
        </p>
      </div>
      <div class="hero-links-block">
        <nav class="hero-links" aria-label="Быстрые ссылки">
          <a class="hero-link" href="#approach"><span aria-hidden="true">→</span> <span>Подход</span></a>
          <a class="hero-link" href="#directions"><span aria-hidden="true">→</span> <span>Услуги</span></a>
          <a class="hero-link" href="#pricing"><span aria-hidden="true">→</span> <span>Стоимость</span></a>
        </nav>
      </div>
    </div>
  </div>
</section>

<script>
  const heroLinks = Array.from(document.querySelectorAll('.hero-links .hero-link'));
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (heroLinks.length > 0 && !prefersReducedMotion.matches) {
    let activeIndex = 0;
    let intervalId;

    const setActive = (index) => {
      heroLinks.forEach((link, linkIndex) => {
        link.classList.toggle('hero-link--active', linkIndex === index);
      });
    };

    const startCycle = () => {
      setActive(activeIndex);
      intervalId = window.setInterval(() => {
        activeIndex = (activeIndex + 1) % heroLinks.length;
        setActive(activeIndex);
      }, 1400);
    };

    const stopCycle = () => {
      if (intervalId) {
        window.clearInterval(intervalId);
        intervalId = undefined;
      }
    };

    heroLinks.forEach((link, index) => {
      link.addEventListener('mouseenter', () => {
        stopCycle();
        activeIndex = index;
        setActive(activeIndex);
      });

      link.addEventListener('focus', () => {
        stopCycle();
        activeIndex = index;
        setActive(activeIndex);
      });

      link.addEventListener('blur', () => {
        if (prefersReducedMotion.matches) return;
        stopCycle();
        startCycle();
      });
    });

    prefersReducedMotion.addEventListener('change', () => {
      stopCycle();
      if (!prefersReducedMotion.matches) {
        startCycle();
      } else {
        heroLinks.forEach((link) => link.classList.remove('hero-link--active'));
      }
    });

    startCycle();
  }
</script>

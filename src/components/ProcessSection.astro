---
const processSteps = [
  {
    step: "01",
    title: "Определяем задачу",
    text: "Фиксируем, что именно требуется, в каком контексте проходит процедура и где нужна экспертная оценка.",
    outputLabel: "Вы получаете",
    output: "Бесплатную консультацию",
  },
  {
    step: "02",
    title: "Первичный аудит",
    text: "Разбираем текущую ситуацию и выявляем точки, требующие коррекции.",
    outputLabel: "Вы получаете",
    output: "Услугу от профессионалов рынка",
  },
  {
    step: "03",
    title: "Внесение улучшений",
    text: "Вы можете исправить несоответствия, а затем самостоятельно подать заявку и пройти ВКС.",
    outputLabel: "ВЫ ПОЛУЧАЕТЕ",
    output: "Выбор: заказать часть услуг или сопровождение под ключ",
  },
];
---

<section id="formats" class="section section--light process-section">
  <div class="section__inner page-container">
    <div class="process-shell framed-block">
      <div class="process-intro section-stack">
        <p class="section__eyebrow">Как работаем</p>
        <h2 class="section__title">
          Мы предлагаем классическую систему сотрудничества.
        </h2>
        <p class="section__lead">
          Каждый этап работы даёт конкретный результат: систему исходных документов, перечень рисков, план доработок и комплект доказательств.
        </p>
      </div>

      <div class="process-grid" aria-label="Этапы работы">
        {processSteps.map((item) => (
          <article class="card card--dark process-step">
            <span class="process-step__number">{item.step}</span>
            <div class="section-stack">
              <h3 class="card__title process-step__title">{item.title}</h3>
              <p class="card__text process-step__text">{item.text}</p>
              <div class="process-step__output">
                <span>{item.outputLabel}</span>
                <strong>{item.output}</strong>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

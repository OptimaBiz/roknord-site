---
const scenarios = [
  {
    id: "scenario-confirmation",
    title: "Подтверждение компетентности",
    text: "Проверяем документы, область, анкету, выборку дел и доказательства до процедуры.",
    evidence: "Область · СМК · ФГИС",
    link: "Связаться",
    href: "#pricing",
  },
  {
    id: "scenario-scope-audit",
    title: "Аудит и актуализация области аккредитации",
    text: "Помогаем выявить риски в области и комплекте приложений до подачи.",
    evidence: "Область · приложения",
    link: "Выбрать",
    href: "#pricing",
  },
  {
    id: "scenario-corrective-actions",
    title: "Корректирующие действия после несоответствий",
    text: "Структурируем корректирующие действия и подтверждающие документы.",
    evidence: "Причина · доказательство · срок",
    link: "Заказать",
    href: "#pricing",
  },
  {
    id: "scenario-primary-accreditation",
    title: "Первичная аккредитация",
    text: "Собираем стартовую логику вокруг области, СМК, записей и фактической практики.",
    evidence: "Документы · практика · структура",
    link: "Узнать",
    href: "#pricing",
  },
  {
    id: "scenario-special-directions",
    title: "Специальные направления",
    text: "Подстраиваем анализ под нетиповую область, отдельную процедуру и повышенный риск.",
    evidence: "Спецобласть · риск · ФГИС",
    link: "Обсудить",
    href: "#pricing",
  },
];
---

<section id="directions" class="section section--light">
  <div class="section__inner section-stack page-container">
    <header class="section-stack section-scope">
      <p class="section__eyebrow">Когда обращаются к нам</p>
      <h2 class="section__title">К нам обращаются, чтобы заранее понять и устранить риски.</h2>
      <p class="section__lead">Выберите ситуацию, которая ближе к вашей.</p>
    </header>

    <div class="scenario-grid" aria-label="Основные сценарии">
      {scenarios.map((item, index) => (
        <article
          id={item.id}
          class="card card--light scenario-card scenario-card--featured"
          style={`--i: ${index}`}
        >
          <span class="card-spotlight" aria-hidden="true"></span>
          <span class="card-ripple" aria-hidden="true"></span>
          <p class="card__meta">Услуга</p>
          <h3 class="card__title">{item.title}</h3>
          <p class="card__text">{item.text}</p>
          <div class="card__deliverable" aria-label="Что обычно проверяем">
            <span>Что проверяем</span>
            <strong>{item.evidence}</strong>
          </div>
          <a class="card__link" href={item.href}>
            <span aria-hidden="true">→</span>
            <span>{item.link}</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Фиксированная структура: элементы карточки выровнены по горизонтали ── */
  @media (min-width: 40rem) {
    .scenario-card {
      grid-template-rows: auto auto 1fr auto auto;
      align-content: stretch;
    }
  }

  /* ── Layered elements above pseudo-elements ────────── */
  .scenario-card--featured > *:not(.card-spotlight):not(.card-ripple) {
    position: relative;
    z-index: 1;
  }

  /* ── Spotlight ──────────────────────────────────────── */
  .card-spotlight {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      circle at var(--mx, 50%) var(--my, 38%),
      rgba(0, 250, 176, 0.12) 0%,
      rgba(0, 250, 176, 0.05) 42%,
      transparent 70%
    );
    transition: opacity 0.3s ease;
  }

  @keyframes card-awake-glow {
    0% {
      opacity: 0;
      transform: scale(0.96);
    }
    45% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1.04);
    }
  }

  @keyframes card-awake-link {
    0% {
      transform: translateX(0);
      letter-spacing: var(--letter-spacing-normal);
    }
    40% {
      transform: translateX(0.25rem);
      letter-spacing: 0.03em;
    }
    100% {
      transform: translateX(0.08rem);
      letter-spacing: var(--letter-spacing-normal);
    }
  }

  @keyframes card-awake-arrow {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(0.2rem);
    }
  }

  /* Desktop hover: spotlight follows cursor */
  @media (hover: hover) {
    .scenario-card--featured.card-entered:hover .card-spotlight {
      opacity: 1;
    }
  }

  /* Press / desktop hover: show spotlight */
  .scenario-card--featured.card-entered.card-touching .card-spotlight,
  .scenario-card--featured.card-entered.card-hovering .card-spotlight {
    opacity: 1;
    transition: opacity 0.15s ease;
  }

  .scenario-card--featured.card-entered.card-awake .card-spotlight {
    opacity: 1;
    background:
      radial-gradient(
        circle at var(--mx, 50%) var(--my, 38%),
        rgba(0, 250, 176, 0.22) 0%,
        rgba(191, 31, 153, 0.12) 34%,
        rgba(0, 250, 176, 0.08) 54%,
        transparent 74%
      );
    animation: card-awake-glow 0.72s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ── Tap ripple ─────────────────────────────────────── */
  .card-ripple {
    position: absolute;
    top: var(--ry, 50%);
    left: var(--rx, 50%);
    z-index: 0;
    border-radius: 50%;
    pointer-events: none;
    width: 4rem;
    height: 4rem;
    transform: translate(-50%, -50%) scale(0);
    background: radial-gradient(circle, rgba(0, 250, 176, 0.28) 0%, transparent 70%);
    opacity: 0;
  }

  @keyframes ripple-burst {
    0%   { transform: translate(-50%, -50%) scale(0);  opacity: 1; }
    60%  { transform: translate(-50%, -50%) scale(6);  opacity: 0.6; }
    100% { transform: translate(-50%, -50%) scale(10); opacity: 0; }
  }

  .scenario-card--featured.card-entered.card-rippling .card-ripple {
    animation: ripple-burst 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* ── Entrance: hidden state ─────────────────────────── */
  .scenario-card--featured {
    scroll-margin-top: calc(var(--header-total-height, 7rem) + var(--space-4));
    opacity: 0;
    border-color: transparent;
    clip-path: polygon(
      0 0,
      100% 0,
      100% 0%,
      var(--editorial-frame-bevel) 0%,
      0 0%
    );
    will-change: clip-path, opacity;
  }

  /* ── Entrance animation ─────────────────────────────── */
  @keyframes card-reveal {
    0% {
      opacity: 0;
      clip-path: polygon(
        0 0,
        100% 0,
        100% 0%,
        var(--editorial-frame-bevel) 0%,
        0 0%
      );
    }
    28% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      clip-path: polygon(
        0 0,
        100% 0,
        100% 100%,
        var(--editorial-frame-bevel) 100%,
        0 calc(100% - var(--editorial-frame-bevel))
      );
    }
  }

  .scenario-card--featured.card-animating {
    animation: card-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    border-color: transparent;
  }

  /* ── Post-entrance state ────────────────────────────── */
  .scenario-card--featured.card-entered {
    opacity: 1;
    border-color: rgba(0, 250, 176, 0.32);
    box-shadow: 0 0 0 0 transparent;
    clip-path: polygon(
      0 0,
      100% 0,
      100% 100%,
      var(--editorial-frame-bevel) 100%,
      0 calc(100% - var(--editorial-frame-bevel))
    );
    animation: none;
    will-change: filter, transform;
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Desktop hover lift */
  @media (hover: hover) {
    .scenario-card--featured.card-entered:hover {
      transform: translateY(-10px) scale(1.018);
      background: rgba(0, 250, 176, 0.08);
      box-shadow: 0 0 0 2px rgba(0, 250, 176, 0.9);
      filter:
        drop-shadow(0 20px 40px rgba(14, 11, 58, 0.32))
        drop-shadow(0 6px 14px rgba(14, 11, 58, 0.2));
    }
  }

  /* Press feedback — desktop click and mobile tap */
  .scenario-card--featured.card-entered.card-touching {
    transform: scale(0.982);
    filter: drop-shadow(0 6px 20px rgba(0, 250, 176, 0.2));
    transition:
      transform 0.12s ease,
      filter 0.12s ease;
  }

  .scenario-card--featured.card-entered.card-awake {
    box-shadow:
      0 0 0 1px rgba(0, 250, 176, 0.95),
      0 18px 44px rgba(14, 11, 58, 0.22);
  }

  .scenario-card--featured.card-entered.card-touching.card-awake {
    transform: scale(0.988);
  }

  .scenario-card--featured.card-entered.card-awake .card__title,
  .scenario-card--featured.card-entered.card-awake .card__text,
  .scenario-card--featured.card-entered.card-awake .card__deliverable {
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scenario-card--featured.card-entered.card-awake .card__title {
    transform: translateY(-0.08rem);
  }

  .scenario-card--featured.card-entered.card-awake .card__deliverable {
    transform: translateY(0.02rem);
  }

  .scenario-card--featured.card-entered.card-awake .card__link {
    position: relative;
    padding: 0.28rem 0.7rem 0.28rem 0.55rem;
    margin-left: -0.55rem;
    border: 1px solid rgba(0, 250, 176, 0.16);
    background: rgba(0, 250, 176, 0.07);
    box-shadow: 0 0 0 1px rgba(191, 31, 153, 0.08) inset;
    color: var(--lrqa-mint-2);
    animation: card-awake-link 0.72s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .scenario-card--featured.card-entered.card-awake .card__link span:first-child {
    animation: card-awake-arrow 0.72s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .scenario-card--featured.card-entered.card-awake .card__link span:last-child {
    text-shadow: 0 0 0.9rem rgba(0, 250, 176, 0.22);
  }

  .scenario-card--featured.card-entered.card-awake .card__link:hover,
  .scenario-card--featured.card-entered.card-awake .card__link:focus-visible {
    transform: translateX(0.12rem);
  }

  @media (hover: none) and (pointer: coarse) {
    .scenario-card--featured.card-entered.card-awake {
      transform: scale(0.993);
      background: linear-gradient(
        180deg,
        rgba(0, 250, 176, 0.1) 0%,
        rgba(255, 255, 255, 0) 58%
      );
    }

    .scenario-card--featured.card-entered.card-awake .card__title {
      transform: translateY(-0.12rem);
    }
  }

  /* ── Deliverable scan-line ──────────────────────────── */
  .card__deliverable {
    position: relative;
    overflow: hidden;
  }

  .card__deliverable::after {
    content: "";
    position: absolute;
    inset-block: 0;
    left: -80%;
    width: 60%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 250, 176, 0.16) 40%,
      rgba(0, 250, 176, 0.26) 50%,
      rgba(0, 250, 176, 0.16) 60%,
      transparent 100%
    );
    opacity: 0;
    pointer-events: none;
  }

  @keyframes deliverable-scan {
    0%   { left: -80%;  opacity: 1; }
    100% { left: 130%;  opacity: 1; }
  }

  /* Press / desktop hover: trigger scan-line */
  .scenario-card--featured.card-entered.card-touching .card__deliverable::after,
  .scenario-card--featured.card-entered.card-hovering .card__deliverable::after {
    animation: deliverable-scan 0.65s cubic-bezier(0.4, 0, 0.6, 1) forwards;
  }

  .scenario-card--featured.card-entered.card-awake .card__deliverable::after {
    opacity: 1;
    animation: deliverable-scan 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ── Reduced motion ─────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .scenario-card--featured,
    .scenario-card--featured.card-animating {
      opacity: 1;
      clip-path: polygon(
        0 0,
        100% 0,
        100% 100%,
        var(--editorial-frame-bevel) 100%,
        0 calc(100% - var(--editorial-frame-bevel))
      );
      animation: none;
      will-change: auto;
    }

    .scenario-card--featured.card-entered {
      border-color: rgba(0, 250, 176, 0.32);
      transition: none;
    }

    .scenario-card--featured.card-entered.card-awake,
    .scenario-card--featured.card-entered.card-touching.card-awake {
      transform: none;
      box-shadow: none;
      background: transparent;
    }

    .scenario-card--featured.card-entered.card-awake .card-spotlight,
    .scenario-card--featured.card-entered.card-awake .card__link,
    .scenario-card--featured.card-entered.card-awake .card__link span:first-child {
      animation: none;
    }

    .scenario-card--featured.card-entered.card-awake .card__link {
      padding: 0;
      margin-left: 0;
      border: 0;
      background: transparent;
      box-shadow: none;
      color: var(--color-mint-action);
    }

    .scenario-card--featured.card-entered.card-awake .card__title,
    .scenario-card--featured.card-entered.card-awake .card__text,
    .scenario-card--featured.card-entered.card-awake .card__deliverable {
      transform: none;
    }

    .card-spotlight,
    .card-ripple {
      display: none;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll(
    '#directions .scenario-card--featured'
  );

  if (cards.length) {
    // Per-card IntersectionObserver — each card animates when it scrolls into view
    cards.forEach((card) => {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry.isIntersecting) return;
          observer.disconnect();

          card.classList.add('card-animating');
          card.addEventListener(
            'animationend',
            () => {
              card.classList.remove('card-animating');
              card.classList.add('card-entered');
            },
            { once: true }
          );
        },
        { threshold: 0 }
      );
      observer.observe(card);
    });

    // Desktop: mouse spotlight
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        if (!card.classList.contains('card-entered')) return;
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${((e.clientX - rect.left) / rect.width) * 100}%`);
        card.style.setProperty('--my', `${((e.clientY - rect.top) / rect.height) * 100}%`);
      });
    });

    // Touch + mouse: spotlight + ripple + scan-line on tap/click/hover
    cards.forEach((card) => {
      let endTimer;
      let hoverTimer;
      let awakeTimer;

      const setEffectPoint = (clientX: number, clientY: number) => {
        if (!card.classList.contains('card-entered')) return;

        const rect = card.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * 100;
        const y = ((clientY - rect.top) / rect.height) * 100;

        card.style.setProperty('--mx', `${x}%`);
        card.style.setProperty('--my', `${y}%`);
        card.style.setProperty('--rx', `${clientX - rect.left}px`);
        card.style.setProperty('--ry', `${clientY - rect.top}px`);
      };

      const startPress = (clientX: number, clientY: number) => {
        if (!card.classList.contains('card-entered')) return;
        clearTimeout(endTimer);
        clearTimeout(awakeTimer);
        setEffectPoint(clientX, clientY);

        card.classList.remove('card-rippling');
        void card.offsetWidth;
        card.classList.add('card-touching', 'card-rippling', 'card-awake');
      };

      const startHover = (clientX: number, clientY: number) => {
        if (!card.classList.contains('card-entered')) return;
        clearTimeout(hoverTimer);
        setEffectPoint(clientX, clientY);

        card.classList.remove('card-rippling', 'card-hovering');
        void card.offsetWidth;
        card.classList.add('card-hovering', 'card-rippling');

        hoverTimer = setTimeout(() => {
          card.classList.remove('card-hovering', 'card-rippling');
        }, 700);
      };

      const endPress = () => {
        endTimer = setTimeout(() => {
          card.classList.remove('card-touching', 'card-rippling');
        }, 380);

        awakeTimer = setTimeout(() => {
          card.classList.remove('card-awake');
        }, 720);
      };

      card.addEventListener('touchstart', (e) => {
        startPress(e.touches[0].clientX, e.touches[0].clientY);
      }, { passive: true });
      card.addEventListener('touchend', endPress, { passive: true });
      card.addEventListener('touchcancel', endPress, { passive: true });

      card.addEventListener('mouseenter', (e) => {
        startHover(e.clientX, e.clientY);
      });
      card.addEventListener('mousedown', (e) => {
        startPress(e.clientX, e.clientY);
      });
      card.addEventListener('mouseup', endPress);
      card.addEventListener('mouseleave', () => {
        clearTimeout(hoverTimer);
        card.classList.remove('card-hovering');
        endPress();
      });
    });
  }
</script>

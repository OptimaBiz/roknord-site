---
import BaseLayout from "../layouts/BaseLayout.astro";

import Hero from "../components/Hero.astro";
import ExpertMaterial from "../components/ExpertMaterial.astro";
import ProofStrip from "../components/ProofStrip.astro";
import RequestStrip from "../components/RequestStrip.astro";
import ContactForm from "../components/ContactForm.astro";
import FaqSection from "../components/FaqSection.astro";
import PricingSection from "../components/PricingSection.astro";
import AudienceSection from "../components/AudienceSection.astro";
import Scenarios from "../components/Scenarios.astro";
import ProcessSection from "../components/ProcessSection.astro";


---

<BaseLayout
  title="Рокнорд — аккредитация и подтверждение компетентности"
  description="Рокнорд помогает выстроить документы, процессы, доказательства и риски в логике проверки — до аккредитации или подтверждения компетентности."
>
  <main id="content">
    <Hero />
    <RequestStrip />
    <ExpertMaterial />
    <ProofStrip />

    <AudienceSection />

    <Scenarios />

    <ProcessSection />

    <PricingSection />
    <ContactForm />
    <FaqSection />
  </main>
</BaseLayout>
